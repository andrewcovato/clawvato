# Clawvato Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Credentials should be stored in macOS Keychain, not here.
# These env vars are only for development/testing fallback.

# Anthropic API Key (required)
ANTHROPIC_API_KEY=

# Slack Tokens (store in Keychain for production)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_USER_TOKEN=

# Google OAuth2 (store in Keychain for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# GitHub Personal Access Token (store in Keychain for production)
GITHUB_PAT=

# Your Slack User ID (for single-principal authority)
OWNER_SLACK_USER_ID=

# Data directory (defaults to ~/.clawvato)
DATA_DIR=

# Log level (debug, info, warn, error)
LOG_LEVEL=info
